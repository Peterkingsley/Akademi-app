DATABASE_URL=postgresql://user:password@localhost:5432/akademi
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite
GOOGLE_TTS_API_KEY=your_google_tts_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here
# Google Custom Search JSON API (image search mode) — sources diagram images for Akademi
# Generated Textbooks. Create a Programmable Search Engine at https://programmablesearchengine.google.com/
# with "Image search" and "Search the entire web" enabled, then enable the "Custom Search API"
# in Google Cloud Console and generate an API key for GOOGLE_CSE_API_KEY. GOOGLE_CSE_ID is the
# search engine's "cx" value from the Programmable Search Engine control panel. Diagram sourcing
# is best-effort — leaving these unset means sections that need a diagram just publish without
# one, nothing breaks.
GOOGLE_CSE_API_KEY=your_google_custom_search_api_key_here
GOOGLE_CSE_ID=your_google_custom_search_engine_id_here
R2_ACCOUNT_ID=your_r2_account_id_here
R2_ACCESS_KEY=your_r2_access_key_here
R2_SECRET_KEY=your_r2_secret_key_here
R2_BUCKET_NAME=akademi-files
R2_PUBLIC_URL=your_r2_public_url_here
RESEND_API_KEY=your_resend_api_key_here
TYPESENSE_HOST=localhost
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=your_typesense_api_key_here
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret_here
SENTRY_DSN=your_sentry_dsn_here
PORT=3000
NODE_ENV=development
