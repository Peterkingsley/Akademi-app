{
  "name": "akademi-backend",
  "version": "1.0.0",
  "description": "AI-powered personalized academic companion app for Nigerian public university students.",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/app.ts",
    "build": "prisma generate && node fix-db.js && tsc",
    "start": "node dist/app.js",
    "migrate": "prisma migrate deploy && npm run seed:admin && npm run seed:universities",
    "seed:universities": "tsx prisma/seed-universities.ts",
    "seed:courses": "tsx prisma/seed-courses.ts",
    "sync:typesense": "tsx src/shared/search/sync-all.ts",
    "migrate:dev": "prisma migrate dev",
    "test": "jest --runInBand",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "seed:admin": "ts-node prisma/seed-admin.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@google-cloud/vision": "^5.3.5",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^10.56.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "redis": "^4.6.14",
    "resend": "^6.9.4",
    "socket.io": "^4.8.3",
    "typesense": "^3.0.6",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.10",
    "@types/pdf-parse": "^1.1.5",
    "@types/socket.io-client": "^1.4.36",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "prisma": "^6.0.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
