generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum AuthProvider {
  EMAIL
  GOOGLE
}

enum VocabularyLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum ReplyMode {
  DIRECT
  STUDY
  QUESTION
  WRONGLY
  SOCRATIC
}

enum SessionType {
  ASSIGNMENT
  STUDY
  EXAM_PREP
}

enum StudyCompanionPhase {
  MATERIAL_SELECTION_REQUIRED
  MATERIAL_SELECTED
  ROADMAP_GENERATED
  TEACHING_PASS_1_BIG_PICTURE
  TEACHING_PASS_2_DETAILS
  TEACHING_PASS_3_CONNECTIONS
  TEACHBACK_1_REQUESTED
  TEACHBACK_1_EVALUATION
  GAP_RETEACH
  TEACHBACK_2_REQUESTED
  TEACHBACK_2_EVALUATION
  MEMORY_DUMP_REQUESTED
  MEMORY_DUMP_EVALUATION
  MASTERY_PASSED
  MASTERY_FAILED
  SECTION_COMPLETED
  NEXT_SECTION_READY
  SESSION_COMPLETED
}

enum StudyRoadmapStatus {
  NOT_STARTED
  IN_PROGRESS
  NEEDS_REVIEW
  MASTERED
}

enum MasteryStatus {
  PASSED
  FAILED
}

enum MessageRole {
  STUDENT
  AI
}

enum FileType {
  PDF
  IMAGE
  DOC
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FLAGGED
  TAKEN_DOWN
}

enum MaterialProcessingStatus {
  UPLOADED
  QUEUED
  EXTRACTING
  EXTRACTED
  FAILED
}

enum ChunkStatus {
  PENDING
  UPLOADED
  ASSEMBLED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Feature {
  ASSIGNMENT_SOLVING
  EXAM_PREP
  QUESTION_REPLY
  WRONGLY_REPLY
}

enum AccessType {
  TIME_WINDOW
  USE_BASED
  FREE_TRIAL
}

enum AdminRole {
  SUPER_ADMIN
  CONTENT_MANAGER
  MODERATOR
  ANALYST
}

enum AdminStatus {
  active
  suspended
}

enum DeviceType {
  ANDROID
  IOS
}

enum CompetitionVisibility {
  PRIVATE
  PUBLIC
  TOURNAMENT
}

enum CompetitionStatus {
  WAITING
  LIVE
  FINISHED
  CANCELLED
}

enum CompetitionFormat {
  SHARED_COURSE
  DUAL_COURSE
}

enum CompetitionParticipantStatus {
  INVITED
  JOINED
  READY
  ELIMINATED
  LEFT
}

enum TournamentStatus {
  DRAFT
  PUBLISHED
  LIVE
  COMPLETED
  CANCELLED
}

enum TournamentEntryStatus {
  REGISTERED
  CHECKED_IN
  STANDBY
  ELIMINATED
  WINNER
}

enum TournamentAudienceScope {
  EVERYONE
  UNIVERSITY
  FACULTY
  DEPARTMENT
}

enum TournamentCampaignType {
  SIMPLE
  MULTI_STAGE
}

enum TournamentStageStatus {
  SCHEDULED
  CHECK_IN
  LIVE
  COMPLETED
  CANCELLED
}

enum TournamentInterestType {
  PARTICIPANT
  SPECTATOR
}

enum TournamentPredictionStatus {
  OPEN
  LOCKED
  CORRECT
  INCORRECT
  WINNER
}

enum MatchSessionStatus {
  LIVE
  FINISHED
}

// Models
model User {
  id                            String       @id @default(uuid())
  name                          String
  email                         String       @unique
  password_hash                 String?
  university                    String
  faculty                       String
  department                    String
  level                         Int
  profile_photo_url             String?
  auth_provider                 AuthProvider @default(EMAIL)
  is_verified                   Boolean      @default(false)
  verification_token            String?
  verification_token_expires_at DateTime?
  created_at                    DateTime     @default(now())
  updated_at                    DateTime     @updatedAt
  is_deleted                    Boolean      @default(false) // Required by AuthService
  is_banned                     Boolean      @default(false)
  push_token                    String?
  courses                       String[]     @default([])

  learning_profile              LearningProfile?
  sessions                      Session[]
  messages                      Message[]
  companion_states              StudyCompanionState[]
  teachback_attempts            TeachBackAttempt[]
  memory_dump_attempts          MemoryDumpAttempt[]
  mastery_records               MasteryRecord[]
  material_memories             StudentMaterialMemory[]
  lesson_plans                  StudySectionLessonPlan[]
  teaching_reflections          TeachingReflection[]
  learning_intelligence_records LearningIntelligenceRecord[]
  tutor_turn_traces             TutorTurnTrace[]
  created_teaching_constraints  LecturerTeachingConstraint[]
  feature_access                FeatureAccess[]
  refresh_tokens                RefreshToken[]
  materials                     Material[]                   @relation("UploadedBy")

  // Relations to additional models used in codebase
  question_attempts             QuestionAttempt[]
  exam_prep_plans               ExamPrepPlan[]
  mock_attempts                 MockAttempt[]
  transactions                  Transaction[]
  notifications                 Notification[]
  student_courses               StudentCourse[]
  hosted_competitions           CompetitionRoom[]             @relation("CompetitionHost")
  competition_entries           CompetitionParticipant[]
  tournament_entries            TournamentEntry[]
  tournament_stage_participants TournamentStageParticipant[]
  tournament_interests          TournamentSpectatorInterest[]
  tournament_predictions        TournamentPrediction[]        @relation("TournamentPredictionUser")
  tournament_predicted_by       TournamentPrediction[]        @relation("TournamentPredictedParticipant")
  tournament_cheers_sent        TournamentCheer[]             @relation("TournamentCheerSpectator")
  tournament_cheers_received    TournamentCheer[]             @relation("TournamentCheerParticipant")

  @@index([email])
  @@index([university])
  @@index([department])
  @@index([created_at])
  @@map("users")
}

model LearningProfile {
  id                           String          @id @default(uuid())
  user_id                      String          @unique
  subject_strengths            Json            @default("{}")
  subject_weaknesses           Json            @default("{}")
  preferred_reply_mode         ReplyMode?
  question_patterns            Json            @default("{}")
  vocabulary_level             VocabularyLevel @default(BASIC)
  session_count                Int             @default(0)
  teaching_strategy_success    Json            @default("{}")
  preferred_teaching_strategy  String?
  preferred_pace               String?
  analogy_success_score        Int             @default(50)
  visual_success_score         Int             @default(50)
  worked_example_success_score Int             @default(50)
  definition_success_score     Int             @default(50)
  problem_first_success_score  Int             @default(50)
  story_success_score          Int             @default(50)
  exam_first_success_score     Int             @default(50)
  calculation_support_needed   Boolean         @default(false)
  visual_support_needed        Boolean         @default(false)
  confidence_support_needed    Boolean         @default(false)
  last_profile_update_at       DateTime?
  last_active                  DateTime?
  updated_at                   DateTime        @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("learning_profiles")
}

model CommunityPattern {
  id               String   @id @default(uuid())
  university       String
  faculty          String
  department       String
  course_code      String?
  question_pattern Json     @default("{}")
  frequency        Int      @default(1)
  updated_at       DateTime @updatedAt

  @@index([department])
  @@index([course_code])
  @@map("community_patterns")
}

model Material {
  id                      String                   @id @default(uuid())
  title                   String
  course_code             String?
  course_id               String?
  university              String
  faculty                 String
  department              String
  level                   Int
  semester                Int?
  semester_start          DateTime?
  semester_end            DateTime?
  academic_year           String?
  file_ref                String
  file_type               FileType
  verification_status     VerificationStatus       @default(PENDING)
  processing_status       MaterialProcessingStatus @default(UPLOADED)
  processing_attempts     Int                      @default(0)
  processing_error        String?                  @db.Text
  processing_started_at   DateTime?
  processing_completed_at DateTime?
  next_retry_at           DateTime?
  upload_count            Int                      @default(1)
  contributor_ids         Json                     @default("[]")
  verified_at             DateTime?
  uploaded_by             String
  admin_reviewed_by       String?
  admin_reviewed_at       DateTime?
  created_at              DateTime                 @default(now())
  content                 String?                  @db.Text
  reader_structure        Json?
  // True for the single, national, system-authored textbook per course code (see
  // GeneratedTextbookOutline). Never set by the student-upload path.
  is_akademi_generated    Boolean                  @default(false)
  generated_outline_id    String?                  @unique

  user                          User                         @relation("UploadedBy", fields: [uploaded_by], references: [id])
  course                        Course?                      @relation(fields: [course_id], references: [id])
  questions                     Question[]
  embeddings                    MaterialEmbedding[]
  teacher_brain                 MaterialTeacherBrain?
  upload_chunks                 UploadChunk[] // Named upload_chunks to match codebase
  sessions                      Session[]
  companion_states              StudyCompanionState[]
  teachback_attempts            TeachBackAttempt[]
  memory_dump_attempts          MemoryDumpAttempt[]
  mastery_records               MasteryRecord[]
  material_memories             StudentMaterialMemory[]
  lesson_plans                  StudySectionLessonPlan[]
  teaching_reflections          TeachingReflection[]
  learning_intelligence_records LearningIntelligenceRecord[]
  tutor_turn_traces             TutorTurnTrace[]
  teaching_constraints          LecturerTeachingConstraint[]
  generated_outline             GeneratedTextbookOutline?    @relation("OutlineMaterial")

  @@index([course_code])
  @@index([course_id])
  @@index([university])
  @@index([department])
  @@index([level])
  @@index([course_code, level, semester])
  @@index([verification_status])
  @@index([processing_status, next_retry_at])
  @@index([course_code, is_akademi_generated])
  @@map("materials")
}

model MaterialTeacherBrain {
  id                  String   @id @default(uuid())
  material_id         String   @unique
  course_code         String?
  university          String
  faculty             String
  department          String
  level               Int
  summary             Json     @default("{}")
  chapter_summaries   Json     @default("[]")
  concept_graph       Json     @default("[]")
  prerequisites       Json     @default("[]")
  formulas            Json     @default("[]")
  calculation_methods Json     @default("[]")
  diagrams            Json     @default("[]")
  misconceptions      Json     @default("[]")
  exam_angles         Json     @default("[]")
  teacher_notes       Json     @default("{}")
  subject_family      String?
  confidence          Int      @default(50)
  generated_at        DateTime @default(now())
  updated_at          DateTime @updatedAt

  material Material @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@index([course_code])
  @@index([department])
  @@index([subject_family])
  @@map("material_teacher_brains")
}

model LecturerTeachingConstraint {
  id                    String   @id @default(uuid())
  material_id           String?
  course_code           String?
  university            String?
  faculty               String?
  department            String?
  level                 Int?
  semester              Int?
  created_by            String
  title                 String
  description           String?  @db.Text
  required_order        Json     @default("[]")
  must_cover_topics     Json     @default("[]")
  do_not_skip_topics    Json     @default("[]")
  preferred_terminology Json     @default("{}")
  required_methods      Json     @default("[]")
  forbidden_methods     Json     @default("[]")
  assessment_focus      Json     @default("[]")
  unit_policy           String?
  proof_policy          String?
  calculation_policy    String?
  diagram_policy        String?
  strictness            String   @default("medium")
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  creator  User      @relation(fields: [created_by], references: [id], onDelete: Cascade)
  material Material? @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@index([material_id])
  @@index([course_code, university, department])
  @@index([created_by])
  @@index([is_active])
  @@map("lecturer_teaching_constraints")
}

model MaterialEmbedding {
  id          String   @id @default(uuid())
  material_id String
  chunk_index Int
  chunk_text  String
  embedding   Json
  created_at  DateTime @default(now())

  material Material @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@map("material_embeddings")
}

model UploadChunk {
  id           String      @id @default(uuid())
  material_id  String
  chunk_index  Int
  chunk_ref    String
  total_chunks Int
  status       ChunkStatus @default(PENDING)
  created_at   DateTime    @default(now())

  material Material @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@map("upload_chunks")
}

model Session {
  id           String      @id @default(uuid())
  user_id      String
  material_id  String?
  session_type SessionType
  reply_mode   ReplyMode?
  course_code  String?
  topic        String?
  duration     Int?
  metadata     Json        @default("{}")
  university   String
  department   String
  started_at   DateTime    @default(now())
  ended_at     DateTime?
  created_at   DateTime    @default(now())

  user                          User                         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  material                      Material?                    @relation(fields: [material_id], references: [id], onDelete: SetNull)
  messages                      Message[]
  companion_state               StudyCompanionState?
  teachbacks                    TeachBackAttempt[]
  memory_dumps                  MemoryDumpAttempt[]
  mastery_records               MasteryRecord[]
  lesson_plans                  StudySectionLessonPlan[]
  teaching_reflections          TeachingReflection[]
  learning_intelligence_records LearningIntelligenceRecord[]
  tutor_turn_traces             TutorTurnTrace[]

  @@index([user_id])
  @@index([material_id])
  @@index([user_id, material_id, session_type])
  @@index([course_code])
  @@index([started_at])
  @@map("sessions")
}

model Message {
  id         String      @id @default(uuid())
  session_id String
  user_id    String
  role       MessageRole
  content    String
  metadata   Json        @default("{}")
  reply_mode ReplyMode?
  created_at DateTime    @default(now())

  session Session @relation(fields: [session_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@map("messages")
}

model StudyCompanionState {
  id                    String              @id @default(uuid())
  session_id            String              @unique
  user_id               String
  material_id           String
  course_code           String
  current_phase         StudyCompanionPhase @default(MATERIAL_SELECTED)
  current_section_index Int                 @default(0)
  last_completed_index  Int                 @default(-1)
  last_mastery_score    Int?
  mastery_threshold     Int                 @default(80)
  roadmap               Json                @default("[]")
  progress              Json                @default("{}")
  section_context       Json                @default("{}")
  refresh_question      String?
  refresh_answer        String?
  pending_prompt        String?
  session_summary       String?
  external_support_used Boolean             @default(false)
  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt

  session                       Session                      @relation(fields: [session_id], references: [id], onDelete: Cascade)
  user                          User                         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  material                      Material                     @relation(fields: [material_id], references: [id], onDelete: Cascade)
  teachbacks                    TeachBackAttempt[]
  memory_dumps                  MemoryDumpAttempt[]
  mastery_records               MasteryRecord[]
  lesson_plans                  StudySectionLessonPlan[]
  teaching_reflections          TeachingReflection[]
  learning_intelligence_records LearningIntelligenceRecord[]

  @@index([user_id, material_id, course_code])
  @@index([current_phase])
  @@map("study_companion_states")
}

model TeachBackAttempt {
  id                 String              @id @default(uuid())
  session_id         String
  companion_state_id String
  user_id            String
  material_id        String
  section_index      Int
  attempt_number     Int
  phase              StudyCompanionPhase
  prompt             String?
  student_response   String
  evaluation         String
  score              Int
  passed             Boolean             @default(false)
  created_at         DateTime            @default(now())

  session         Session             @relation(fields: [session_id], references: [id], onDelete: Cascade)
  companion_state StudyCompanionState @relation(fields: [companion_state_id], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  material        Material            @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@index([session_id, section_index, attempt_number])
  @@index([companion_state_id, section_index])
  @@map("teachback_attempts")
}

model MemoryDumpAttempt {
  id                 String   @id @default(uuid())
  session_id         String
  companion_state_id String
  user_id            String
  material_id        String
  section_index      Int
  prompt             String?
  student_response   String
  evaluation         String
  score              Int
  created_at         DateTime @default(now())

  session         Session             @relation(fields: [session_id], references: [id], onDelete: Cascade)
  companion_state StudyCompanionState @relation(fields: [companion_state_id], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  material        Material            @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@index([session_id, section_index])
  @@index([companion_state_id, section_index])
  @@map("memory_dump_attempts")
}

model MasteryRecord {
  id                 String        @id @default(uuid())
  session_id         String
  companion_state_id String
  user_id            String
  material_id        String
  course_code        String
  section_index      Int
  section_title      String
  score              Int
  status             MasteryStatus
  failed_concepts    Json          @default("[]")
  created_at         DateTime      @default(now())

  session         Session             @relation(fields: [session_id], references: [id], onDelete: Cascade)
  companion_state StudyCompanionState @relation(fields: [companion_state_id], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  material        Material            @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@index([user_id, course_code, material_id])
  @@index([companion_state_id, section_index])
  @@map("mastery_records")
}

model StudentMaterialMemory {
  id                          String   @id @default(uuid())
  user_id                     String
  material_id                 String
  course_code                 String
  section_index               Int
  section_title               String
  mastered                    Boolean  @default(false)
  mastery_score               Int?
  understood                  Json     @default("[]")
  weak_points                 Json     @default("[]")
  misconceptions              Json     @default("[]")
  calculation_issues          Json     @default("[]")
  diagram_issues              Json     @default("[]")
  preferred_explanation_style String?
  revisit_later               Json     @default("[]")
  compressed_summary          String?  @db.Text
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  material Material @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@index([user_id, material_id, course_code])
  @@index([user_id, material_id, section_index])
  @@map("student_material_memories")
}

model StudySectionLessonPlan {
  id                   String   @id @default(uuid())
  session_id           String
  companion_state_id   String
  user_id              String
  material_id          String
  course_code          String
  section_index        Int
  section_title        String
  lesson_objective     String
  prerequisite_refresh Json     @default("[]")
  teaching_sequence    Json     @default("[]")
  analogy_plan         Json     @default("[]")
  calculation_plan     Json     @default("[]")
  diagram_plan         Json     @default("[]")
  checkpoint_focus     Json     @default("[]")
  exam_focus           Json     @default("[]")
  fallback_plan        Json     @default("[]")
  generated_at         DateTime @default(now())
  updated_at           DateTime @updatedAt

  session         Session             @relation(fields: [session_id], references: [id], onDelete: Cascade)
  companion_state StudyCompanionState @relation(fields: [companion_state_id], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  material        Material            @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@index([session_id, section_index])
  @@index([user_id, material_id, course_code])
  @@map("study_section_lesson_plans")
}

model TeachingReflection {
  id                        String   @id @default(uuid())
  session_id                String
  companion_state_id        String
  user_id                   String
  material_id               String
  course_code               String
  section_index             Int
  section_title             String
  strategy_used             String?
  pace_used                 String?
  repair_mode_used          String?
  analogy_used              Boolean  @default(false)
  worked_example_used       Boolean  @default(false)
  visual_explanation_used   Boolean  @default(false)
  calculation_steps_used    Boolean  @default(false)
  exam_framing_used         Boolean  @default(false)
  challenge_used            Boolean  @default(false)
  mastery_score             Int?
  concept_understanding     Int?
  procedural_accuracy       Int?
  reasoning_quality         Int?
  confidence                Int?
  hidden_confusion_risk     Int?
  what_worked               Json     @default("[]")
  what_failed               Json     @default("[]")
  recommended_next_strategy String?
  recommended_next_pace     String?
  recommended_interventions Json     @default("[]")
  compressed_reflection     String?  @db.Text
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  session         Session             @relation(fields: [session_id], references: [id], onDelete: Cascade)
  companion_state StudyCompanionState @relation(fields: [companion_state_id], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  material        Material            @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@index([user_id, material_id, course_code])
  @@index([session_id, section_index])
  @@index([strategy_used])
  @@map("teaching_reflections")
}

model LearningIntelligenceRecord {
  id                    String   @id @default(uuid())
  session_id            String
  companion_state_id    String
  user_id               String
  material_id           String
  course_code           String
  section_index         Int
  section_title         String
  mastery_score         Int?
  concept_understanding Int      @default(50)
  procedural_accuracy   Int      @default(50)
  reasoning_quality     Int      @default(50)
  confidence            Int      @default(50)
  hidden_confusion_risk Int      @default(50)
  retention_risk        Int      @default(50)
  calculation_weakness  Boolean  @default(false)
  diagram_weakness      Boolean  @default(false)
  prerequisite_weakness Boolean  @default(false)
  evidence              Json     @default("{}")
  recommended_action    String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  session         Session             @relation(fields: [session_id], references: [id], onDelete: Cascade)
  companion_state StudyCompanionState @relation(fields: [companion_state_id], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  material        Material            @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@index([user_id, material_id, course_code])
  @@index([session_id, section_index])
  @@index([hidden_confusion_risk])
  @@index([retention_risk])
  @@map("learning_intelligence_records")
}

model TutorTurnTrace {
  id                       String   @id @default(uuid())
  session_id               String
  user_id                  String
  material_id              String?
  course_code              String?
  section_index            Int?
  section_title            String?
  phase                    String
  turn_type                String?
  action                   String?
  teacher_brain_used       Boolean  @default(false)
  student_memory_used      Boolean  @default(false)
  lesson_plan_used         Boolean  @default(false)
  relevant_material_used   Boolean  @default(false)
  calculation_context_used Boolean  @default(false)
  diagram_context_used     Boolean  @default(false)
  quality_guardrail_used   Boolean  @default(false)
  quality_issues           Json     @default("[]")
  prompt_tokens_estimate   Int?
  response_chars           Int?
  latency_ms               Int?
  ai_latency_ms            Int?
  error_message            String?
  metadata                 Json     @default("{}")
  created_at               DateTime @default(now())

  session  Session   @relation(fields: [session_id], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  material Material? @relation(fields: [material_id], references: [id], onDelete: SetNull)

