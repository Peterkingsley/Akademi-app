generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum VocabularyLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum ReplyMode {
  DIRECT
  STUDY
  QUESTION
  WRONGLY
}

enum SessionType {
  ASSIGNMENT
  STUDY
  TUTOR
  EXAM_PREP
}

enum MessageRole {
  STUDENT
  AI
}

enum FileType {
  PDF
  IMAGE
  DOC
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FLAGGED
  TAKEN_DOWN
}

enum ChunkStatus {
  PENDING
  UPLOADED
  ASSEMBLED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Feature {
  ASSIGNMENT_SOLVING
  LIVE_TUTORING
  EXAM_PREP
  QUESTION_REPLY
  WRONGLY_REPLY
}

enum AccessType {
  TIME_WINDOW
  USE_BASED
}

enum AdminRole {
  SUPER_ADMIN
  MODERATOR
}

enum DeviceType {
  ANDROID
  IOS
}

model User {
  id                            String           @id @default(uuid())
  name                          String
  email                         String           @unique
  password_hash                 String?
  university                    String
  faculty                       String
  department                    String
  level                         Int
  profile_photo_url             String?
  auth_provider                 AuthProvider
  is_verified                   Boolean          @default(false)
  verification_token            String?
  verification_token_expires_at DateTime?
  created_at                    DateTime         @default(now())
  updated_at                    DateTime         @updatedAt
  is_deleted                    Boolean          @default(false)
  learning_profile              LearningProfile?
  materials                     Material[]
  sessions                      Session[]
  messages                      Message[]
  feature_access                FeatureAccess[]
  refresh_tokens                RefreshToken[]
  exam_prep_plans               ExamPrepPlan[]
  mock_attempts                 MockAttempt[]
  question_attempts             QuestionAttempt[]

  @@index([email])
  @@index([university])
  @@index([department])
  @@map("users")
}

model LearningProfile {
  id                   String          @id @default(uuid())
  user_id              String          @unique
  user                 User            @relation(fields: [user_id], references: [id])
  subject_strengths    Json
  subject_weaknesses   Json
  preferred_reply_mode ReplyMode?
  question_patterns    Json
  vocabulary_level     VocabularyLevel
  session_count        Int             @default(0)
  last_active          DateTime?
  updated_at           DateTime        @updatedAt

  @@map("learning_profiles")
}

model CommunityPattern {
  id               String   @id @default(uuid())
  university       String
  faculty          String
  department       String
  course_code      String
  question_pattern Json
  frequency        Int      @default(1)
  updated_at       DateTime @updatedAt

  @@index([department])
  @@index([course_code])
  @@map("community_patterns")
}

model Material {
  id                  String             @id @default(uuid())
  title               String
  course_code         String
  university          String
  faculty             String
  department          String
  level               Int
  file_ref            String
  file_type           FileType
  verification_status VerificationStatus
  upload_count        Int                @default(1)
  contributor_ids     Json
  verified_at         DateTime?
  uploaded_by         String
  user                User               @relation(fields: [uploaded_by], references: [id])
  admin_reviewed_by   String?
  admin               Admin?             @relation(fields: [admin_reviewed_by], references: [id])
  admin_reviewed_at   DateTime?
  created_at          DateTime           @default(now())
  embeddings          MaterialEmbedding[]
  upload_chunks       UploadChunk[]
  questions           Question[]

  @@index([course_code])
  @@index([university])
  @@index([department])
  @@index([level])
  @@index([verification_status])
  @@map("materials")
}

model MaterialEmbedding {
  id          String   @id @default(uuid())
  material_id String
  material    Material @relation(fields: [material_id], references: [id])
  chunk_index Int
  chunk_text  String
  embedding   Json
  created_at  DateTime @default(now())

  @@map("material_embeddings")
}

model UploadChunk {
  id           String      @id @default(uuid())
  material_id  String
  material     Material    @relation(fields: [material_id], references: [id])
  chunk_index  Int
  chunk_ref    String
  total_chunks Int
  status       ChunkStatus
  created_at   DateTime    @default(now())

  @@map("upload_chunks")
}

model Session {
  id           String      @id @default(uuid())
  user_id      String
  user         User        @relation(fields: [user_id], references: [id])
  session_type SessionType
  reply_mode   ReplyMode?
  course_code  String
  university   String
  department   String
  started_at   DateTime    @default(now())
  ended_at     DateTime?
  created_at   DateTime    @default(now())
  messages     Message[]

  @@index([user_id])
  @@index([course_code])
  @@map("sessions")
}

model Message {
  id         String      @id @default(uuid())
  session_id String
  session    Session     @relation(fields: [session_id], references: [id])
  user_id    String
  user       User        @relation(fields: [user_id], references: [id])
  role       MessageRole
  content    String
  reply_mode ReplyMode?
  created_at DateTime    @default(now())

  @@index([session_id])
  @@map("messages")
}

model Question {
  id             String     @id @default(uuid())
  material_id    String
  material       Material   @relation(fields: [material_id], references: [id])
  course_code    String
  university     String
  department     String
  level          Int
  question_text  String
  approach_guide String
  difficulty     Difficulty
  generated_at   DateTime   @default(now())

  attempts       QuestionAttempt[]
  mock_exams     MockExam[]

  @@index([course_code])
  @@index([department])
  @@index([difficulty])
  @@map("questions")
}

model FeatureAccess {
  id             String     @id @default(uuid())
  user_id        String
  user           User       @relation(fields: [user_id], references: [id])
  feature        Feature
  access_type    AccessType
  expires_at     DateTime?
  uses_remaining Int?
  purchased_at   DateTime   @default(now())
  payment_ref    String

  @@index([user_id])
  @@index([feature])
  @@map("feature_access")
}

model Admin {
  id                   String               @id @default(uuid())
  name                 String
  email                String               @unique
  password_hash        String
  role                 AdminRole
  created_at           DateTime             @default(now())
  last_login           DateTime?
  reviewed_materials   Material[]
  discipline_documents DisciplineDocument[]

  @@map("admins")
}

model RefreshToken {
  id          String     @id @default(uuid())
  user_id     String
  user        User       @relation(fields: [user_id], references: [id])
  token_hash  String
  device_name String
  device_type DeviceType
  is_active   Boolean    @default(true)
  created_at  DateTime   @default(now())
  expires_at  DateTime

  @@index([user_id])
  @@index([is_active])
  @@map("refresh_tokens")
}

model DisciplineDocument {
  id              String   @id @default(uuid())
  faculty         String
  department      String
  course_code     String?
  document_ref    String
  version         Int      @default(1)
  last_updated_by String
  admin           Admin    @relation(fields: [last_updated_by], references: [id])
  updated_at      DateTime @updatedAt
  is_active       Boolean  @default(true)

  @@index([department])
  @@index([course_code])
  @@index([is_active])
  @@map("discipline_documents")
}

model University {
  id          String       @id @default(uuid())
  name        String       @unique
  location    String?
  departments Department[]
  created_at  DateTime     @default(now())

  @@map("universities")
}

model Department {
  id            String     @id @default(uuid())
  name          String
  university_id String
  university    University @relation(fields: [university_id], references: [id])
  faculty       String
  created_at    DateTime   @default(now())

  @@unique([name, university_id])
  @@map("departments")
}

model ExamPrepPlan {
  id           String     @id @default(uuid())
  user_id      String
  user         User       @relation(fields: [user_id], references: [id])
  course_code  String
  exam_date    DateTime
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  tasks        PrepTask[]
  mock_exams   MockExam[]

  @@index([user_id])
  @@map("exam_prep_plans")
}

model PrepTask {
  id           String       @id @default(uuid())
  plan_id      String
  plan         ExamPrepPlan @relation(fields: [plan_id], references: [id])
  title        String
  description  String?
  due_date     DateTime
  completed    Boolean      @default(false)
  completed_at DateTime?
  created_at   DateTime     @default(now())

  @@map("prep_tasks")
}

model MockExam {
  id          String       @id @default(uuid())
  plan_id     String
  plan        ExamPrepPlan @relation(fields: [plan_id], references: [id])
  title       String
  questions   Question[]
  created_at  DateTime     @default(now())
  attempts    MockAttempt[]

  @@map("mock_exams")
}

model MockAttempt {
  id             String    @id @default(uuid())
  mock_exam_id   String
  mock_exam      MockExam  @relation(fields: [mock_exam_id], references: [id])
  user_id        String
  user           User      @relation(fields: [user_id], references: [id])
  score          Float
  feedback       String?
  started_at     DateTime  @default(now())
  completed_at   DateTime?

  @@map("mock_attempts")
}

model QuestionAttempt {
  id          String   @id @default(uuid())
  question_id String
  question    Question @relation(fields: [question_id], references: [id])
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  answer      String
  is_correct  Boolean
  feedback    String?
  created_at  DateTime @default(now())

  @@map("question_attempts")
}
