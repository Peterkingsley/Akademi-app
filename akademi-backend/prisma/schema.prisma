enum DisciplineDocumentSourceType {
  CCMAS
  INTERNATIONAL_REFERENCE
}

model DisciplineDocument {
  id                     String                       @id @default(uuid())
  faculty                String
  department             String
  course_code            String?
  // CCMAS (government curriculum) or a named international reference curriculum. Only
  // CCMAS documents are ever used as the decomposition backbone for generated textbooks.
  source_type            DisciplineDocumentSourceType @default(CCMAS)
  // Name of the international curriculum this document represents, e.g. "MIT OCW — 8.01".
  // Required in practice for INTERNATIONAL_REFERENCE rows, null for CCMAS.
  reference_name         String?
  // Course level (100/200/...), admin-specified. Only meaningful for course_code-scoped
  // CCMAS documents — this is what a generated textbook's Material.level is sourced from,
  // since DisciplineDocument has no other reliable way to know a course's level.
  level                  Int?
  document_ref           String
  version                Int                          @default(1)
  version_notes          String?
  last_updated_by        String
  updated_at             DateTime                     @updatedAt
  is_active              Boolean                      @default(true)
  // Set on a per-course document created by splitting a department-wide CCMAS document
  // (admin.service.ts's previewDisciplineDocumentSplit/confirmDisciplineDocumentSplit) —
  // traceability back to the source document it was extracted from. Null for everything else.
  split_from_document_id String?

  generated_textbook_outlines GeneratedTextbookOutline[]
  split_from                  DisciplineDocument?        @relation("DocumentSplit", fields: [split_from_document_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  split_children              DisciplineDocument[]       @relation("DocumentSplit")

  @@index([department])
  @@index([course_code])
  @@index([is_active])
  @@index([course_code, source_type])
  @@index([split_from_document_id])
  @@map("discipline_documents")
}

enum OutlineNodeStatus {
  PENDING
  GENERATING
  GENERATED
  FAILED_QUALITY_CHECK
  ADMIN_QUEUED
}

model GeneratedTextbookOutline {
  id                   String   @id @default(uuid())
  course_code          String
  ccmas_version        Int
  ccmas_document_id    String
  // Denormalized pointer to the Material this outline publishes to, written in the same
  // transaction as the Material create. Not a DB-enforced bidirectional relation — Prisma
  // can only own the FK on one side (Material.generated_outline_id is the real relation).
  // Invariant: always write both sides together, never independently.
  material_id          String?  @unique
  terminology_registry Json     @default("{}")
  is_current           Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  ccmas_document DisciplineDocument             @relation(fields: [ccmas_document_id], references: [id])
  nodes          GeneratedTextbookOutlineNode[]
  material       Material?                      @relation("OutlineMaterial", fields: [material_id], references: [id])

  @@index([course_code])
  @@index([course_code, is_current])
  @@index([ccmas_document_id])
  @@map("generated_textbook_outlines")
}

model GeneratedTextbookOutlineNode {
  id                        String            @id @default(uuid())
  outline_id                String
  parent_id                 String?
  order_index               Int
  depth                     Int
  title                     String
  learning_outcome          String            @db.Text
  // Internal bookkeeping only for dedup/placement during decomposition and later debugging —
  // never exposed to students as a formal citation, per spec.
  is_international_addition Boolean           @default(false)
  status                    OutlineNodeStatus @default(PENDING)
  retry_count               Int               @default(0)
  created_at                DateTime          @default(now())
  updated_at                DateTime          @updatedAt

  outline  GeneratedTextbookOutline       @relation(fields: [outline_id], references: [id], onDelete: Cascade)
  // Self-referencing tree. onDelete/onUpdate NoAction: Postgres/Prisma can't cascade-delete
  // a self-referencing tree cleanly — whole-outline cleanup goes through outline_id's cascade
  // instead, which deletes every node (parent and child) in one pass regardless of order.
  parent   GeneratedTextbookOutlineNode?  @relation("NodeChildren", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children GeneratedTextbookOutlineNode[] @relation("NodeChildren")
  section  GeneratedTextbookSection?

  @@index([outline_id, parent_id, order_index])
  @@index([outline_id, status])
  @@map("generated_textbook_outline_nodes")
}

model GeneratedTextbookSection {
  id                   String   @id @default(uuid())
  node_id              String   @unique
  content              String   @db.Text
  needs_diagram        Boolean  @default(false)
  diagram_description  String?  @db.Text
  diagram_image_url    String?
  quality_check_passed Boolean  @default(false)
  quality_check_notes  String?  @db.Text
  generated_at         DateTime @default(now())

  node GeneratedTextbookOutlineNode @relation(fields: [node_id], references: [id], onDelete: Cascade)

  @@map("generated_textbook_sections")
}

