apiVersion: v1
kind: Secret
metadata:
  name: akademi-secrets
type: Opaque
data:
  DATABASE_URL: <base64-encoded-url>
  REDIS_URL: <base64-encoded-url>
  JWT_SECRET: <base64-encoded-secret>
  JWT_REFRESH_SECRET: <base64-encoded-secret>
  CLAUDE_API_KEY: <base64-encoded-key>
  GOOGLE_TTS_API_KEY: <base64-encoded-key>
  R2_ACCOUNT_ID: <base64-encoded-id>
  R2_ACCESS_KEY: <base64-encoded-key>
  R2_SECRET_KEY: <base64-encoded-key>
  R2_BUCKET_NAME: <base64-encoded-name>
  TYPESENSE_API_KEY: <base64-encoded-key>
  PAYSTACK_SECRET_KEY: <base64-encoded-key>
  SENTRY_DSN: <base64-encoded-dsn>
